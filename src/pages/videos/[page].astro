---
import { siteConfig } from "../../config";
import { fetchYouTubeVideos, hasYouTubeApiKey } from "../../lib/fetch-youtube-videos";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.vue";
import VideoGrid from "../../components/VideoGrid.vue";
import Footer from "../../components/Footer.astro";
import { getImage } from "astro:assets";
import logo from "../../assets/logo.png";

export async function getStaticPaths() {
  const PAGE_SIZE = 10;
  const allVideos = await fetchYouTubeVideos();
  const noApiKey = !hasYouTubeApiKey();
  const totalPages = Math.max(1, Math.ceil(allVideos.length / PAGE_SIZE));
  const paths = [];

  for (let page = 1; page <= totalPages; page++) {
    const start = (page - 1) * PAGE_SIZE;
    const end = start + PAGE_SIZE;
    paths.push({
      params: { page: String(page) },
      props: {
        videos: allVideos.slice(start, end),
        pagination: {
          currentPage: page,
          lastPage: totalPages,
          total: allVideos.length,
          prevUrl: page > 1 ? (page === 2 ? "/videos" : `/videos/${page - 1}`) : null,
          nextUrl: page < totalPages ? `/videos/${page + 1}` : null,
        },
        noApiKey,
      },
    });
  }

  return paths;
}

const { videos, pagination, noApiKey } = Astro.props;
const section = siteConfig.videos;
const logoOptimized = await getImage({ src: logo, format: "webp" });
---

<BaseLayout title={`${section.title} — L'atelier Psy`} description={section.text}>
  <Nav client:load logoSrc={logoOptimized.src} navLinks={siteConfig.nav.links} navActions={siteConfig.nav.actions} />

  <section class="relative bg-brand grain overflow-hidden">
    <div class="dot-pattern absolute inset-0 pointer-events-none"></div>
    <div class="max-w-6xl mx-auto px-6 py-16 md:py-20 relative text-center">
      <span class="text-xs font-bold tracking-widest uppercase text-neutral block mb-4 animate-fade-up">{section.surtitle}</span>
      <h1 class="font-pronell text-4xl md:text-5xl font-normal leading-[1.05] text-white tracking-tight animate-fade-up-2">{section.title}</h1>
      <p class="text-base text-neutral/80 leading-relaxed max-w-lg mx-auto mt-4 animate-fade-up-3">{section.text}</p>
      {pagination.total > 0 && (
        <p class="text-xs text-neutral/50 mt-2 animate-fade-up-3">{pagination.total} vidéos</p>
      )}
    </div>
  </section>

  <section class="bg-surface-2 py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <VideoGrid client:load videos={videos} pagination={pagination} noApiKey={noApiKey} />
    </div>
  </section>

  <Footer />
</BaseLayout>