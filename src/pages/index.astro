---
import { getImage } from "astro:assets";
import { siteConfig } from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.vue";
import Hero from "../components/Hero.astro";
import Newsletter from "../components/Newsletter.astro";
import Ateliers from "../components/Ateliers.astro";
import Contenus from "../components/Contenus.astro";
import Equipe from "../components/Equipe.astro";
import Livre from "../components/Livre.astro";
import Footer from "../components/Footer.astro";
import logo from "../assets/logo.png";

const logoOptimized = await getImage({ src: logo, format: "webp" });
---

<BaseLayout>
  <Nav client:load logoSrc={logoOptimized.src} navLinks={siteConfig.nav.links} navActions={siteConfig.nav.actions} />
  <Hero />
  <Newsletter />
  <Ateliers />
  <Contenus />
  <Equipe />
  <Livre />
  <Footer />
</BaseLayout>
