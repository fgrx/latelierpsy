---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";

const currentYear = new Date().getFullYear();

const linkMap: Record<string, string> = {
  "Qui sommes-nous ?": "/qui-sommes-nous",
  Contact: "/contact",
  Supervisions: "/supervisions",
  "Le livre": "/livre-catherine-la-psy",
  FAQ: "/faq",
  "Mentions légales": "/mentions-legales",
  "Contenus psy": "/#contenus",
  "La Lettre Psy": "/lettre-psy",
  Podcast: "/podcast",
  Vidéos: "/videos",
  "Articles psy": "/posts",
};

const socials = [
  {
    name: "linkedin",
    href: "https://fr.linkedin.com/in/catherine-la-psy-4a4a4416a",
  },
  {
    name: "youtube",
    href: "https://www.youtube.com/@catherinelapsy",
  },
  { name: "podcast", href: "/podcast" },
];

const columns = [
  {
    title: "Ateliers psy",
    links: [
      "Estime de soi",
      "Stabilisation émotionnelle",
      "Souffrances relationnelles",
      "Plan de traitement",
      "Packs d'ateliers",
    ],
  },
  {
    title: "L'atelier",
    links: [
      "Contenus psy",
      "La Lettre Psy",
      "Podcast",
      "Vidéos",
      "Articles psy",
    ],
  },
  {
    title: "Informations",
    links: [
      "Qui sommes-nous ?",
      "Contact",
      "Supervisions",
      "Le livre",
      "FAQ",
      "Mentions légales",
    ],
  },
];
---

<footer id="contact" class="bg-ink pt-14 pb-0">
  <div
    class="max-w-6xl mx-auto px-6 grid sm:grid-cols-2 lg:grid-cols-4 gap-10 pb-10 border-b border-white/8"
  >
    <div>
      <div class="flex items-center gap-3 mb-4">
        <a href="/">
          <Image
            src={logo}
            alt="L'atelier psy"
            class="h-20 w-auto"
            format="webp"
          />
        </a>
      </div>
      <p class="text-[13px] text-white/45 leading-relaxed mb-5 max-w-[220px]">
        Des ateliers de psychothérapie en ligne pour démocratiser la
        psychothérapie et commencer le travail chez vous.
      </p>
      <div class="flex gap-2">
        {
          socials.map((social) => (
            <a
              href={social.href}
              target={social.name === "linkedin" ? "_blank" : undefined}
              rel={
                social.name === "linkedin" ? "noopener noreferrer" : undefined
              }
              class="w-9 h-9 rounded-lg bg-white/8 flex items-center justify-center text-white/50 hover:bg-white/14 hover:text-white transition-all duration-200"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                viewBox="0 0 24 24"
              >
                {social.name === "linkedin" && (
                  <>
                    <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z" />
                    <rect x="2" y="9" width="4" height="12" />
                    <circle cx="4" cy="4" r="2" />
                  </>
                )}
                {social.name === "youtube" && (
                  <>
                    <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.95 1.95C5.12 20 12 20 12 20s6.88 0 8.59-.47a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58z" />
                    <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" />
                  </>
                )}
                {social.name === "podcast" && (
                  <>
                    <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z" />
                    <path d="M19 10v2a7 7 0 01-14 0v-2" />
                    <line x1="12" y1="19" x2="12" y2="23" />
                    <line x1="8" y1="23" x2="16" y2="23" />
                  </>
                )}
              </svg>
            </a>
          ))
        }
      </div>
    </div>

    {
      columns.map((col) => (
        <div>
          <div class="text-[10px] font-bold uppercase tracking-widest text-neutral mb-4">
            {col.title}
          </div>
          {col.links.map((l) => (
            <a
              href={linkMap[l] || "#"}
              class="block text-[13px] text-white/50 hover:text-white transition-colors mb-2 font-normal text-left"
            >
              {l}
            </a>
          ))}
        </div>
      ))
    }
  </div>

  <div
    class="max-w-6xl mx-auto px-6 py-4 flex flex-wrap justify-between items-center gap-3 text-[12px] text-white/25"
  >
    <span>© {currentYear} L'atelier psy — Tous droits réservés</span>
    <div class="flex gap-5">
      <a
        href="/mentions-legales"
        class="text-white/25 hover:text-white/50 transition-colors"
        >Mentions légales</a
      >
      <a
        href="/politique-de-confidentialite"
        class="text-white/25 hover:text-white/50 transition-colors"
        >Politique de confidentialité</a
      >
    </div>
  </div>
</footer>
