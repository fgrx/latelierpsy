---
import { Image } from "astro:assets";
import couverture from "../assets/Bienvenue-chez-le-psy.jpg";
import { siteConfig } from "../config";

const section = siteConfig.livre;
const titleLines = section.title.split("\n");
---

<section class="bg-coral py-16 md:py-24 relative overflow-hidden">
  <div
    class="animate-float absolute -top-20 -right-20 w-80 h-80 rounded-full bg-white/5 pointer-events-none"
  >
  </div>
  <div
    class="animate-float absolute -bottom-16 -left-16 w-56 h-56 rounded-full bg-white/5 pointer-events-none"
    style="animation-delay: 1.5s"
  >
  </div>

  <div
    class="max-w-6xl mx-auto px-6 grid md:grid-cols-[320px_1fr] gap-12 md:gap-20 items-center"
  >
    <div class="reveal relative mx-auto md:mx-0" style="max-width: 320px">
      <div class="relative rounded-2xl shadow-2xl overflow-hidden">
        <Image
          src={couverture}
          format="webp"
          alt={section.title.replace("\n", " ")}
          class="w-full h-auto block"
        />
      </div>
      <div
        class="animate-float absolute -top-4 -right-4 w-[70px] h-[70px] rounded-full bg-gold flex flex-col items-center justify-center shadow-lg shadow-gold/40 text-2xs font-bold uppercase tracking-wide text-ink leading-tight text-center"
      >
        Notre<br />livre
      </div>
    </div>

    <div class="reveal reveal-d1">
      <span
        class="text-xs font-bold tracking-widest uppercase text-white/50 block mb-4"
        >{section.surtitle}</span
      >
      <h2
        class="font-pronell text-4xl md:text-5xl font-normal text-white leading-tight mb-2"
      >
        {
          titleLines.map((line, i) => (
            <>
              {i > 0 && <br />}
              {line}
            </>
          ))
        }
      </h2>
      <div class="font-aveton text-lg text-white/75 mb-6">
        {section.subtitle}
      </div>
      <p class="text-base leading-relaxed text-white/85 mb-8">
        {section.text}
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          target="blank"
          href="https://www.deboecksuperieur.com/livre/9782807348172-bienvenue-chez-le-psy"
          class="btn-shine text-sm font-semibold px-8 py-3 rounded-full bg-white text-coral hover:bg-red-50 transition-colors shadow-lg"
        >
          Commander le livre →
        </a>
        <a
          href="/livre-catherine-la-psy"
          class="text-sm font-semibold px-6 py-3 rounded-full border-[1.5px] border-white/40 text-white hover:bg-white/10 transition-all duration-200"
        >
          En savoir plus
        </a>
      </div>
    </div>
  </div>
</section>
