---
import NewsletterForm from "./NewsletterForm.vue";
import { siteConfig } from "../config";
import { getAllStats } from "../lib/fetch-stats";

const newsletter = siteConfig.newsletter;
const stats = await getAllStats();
---

<div class="not-prose reveal">
  <div class="bg-white rounded-2xl border border-border shadow-xl shadow-brand/10 p-8 md:p-10 max-w-lg mx-auto text-center">
    <div class="font-aveton text-xl text-ink mb-1">
      S'abonner à la Lettre Psy
    </div>
    <div class="text-sm text-ink-faint mb-6">Rejoignez les {stats.lettrePsy.value} lecteurs</div>
    <NewsletterForm
      client:load
      count={stats.lettrePsy.value}
      apiUrl={newsletter.apiUrl}
      campaignId={newsletter.defaultCampaignId}
    />
  </div>
</div>
