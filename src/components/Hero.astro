---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { siteConfig } from "../config";
import { getAllStats } from "../lib/fetch-stats";

const PHOTO_CATE_FAB =
  "https://res.cloudinary.com/dyyzsnhr4/image/upload/v1659690331/medium_catefab_photo_b963c63c77.webp";

const allAteliers = await getCollection("ateliers");
const activeAteliersCount = allAteliers.filter((a) => a.data.isActive === true || a.data.active === true).length;

const stats = await getAllStats();
const hero = siteConfig.hero;
---

<section class="relative bg-brand grain">
  <div class="dot-pattern absolute inset-0 pointer-events-none"></div>
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row md:items-center">
    <div class="relative order-2 md:order-1 md:flex-1 animate-fade-in">
      <Image
        src={PHOTO_CATE_FAB}
        alt="Catherine et Fabien"
        width={750}
        height={500}
        format="webp"
        class="w-full h-auto block"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-brand pointer-events-none hidden md:block"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-brand via-transparent to-transparent pointer-events-none md:hidden"></div>
    </div>

    <div class="order-1 md:order-2 md:flex-1 px-6 md:px-12 py-16 md:py-20 flex flex-col justify-center">
      <div class="flex items-center gap-3 mb-5 animate-fade-up">
        <span class="block w-8 h-0.5 bg-neutral shrink-0"></span>
        <span class="text-xs font-bold tracking-widest uppercase text-neutral">
          {hero.surtitle}
        </span>
      </div>
      <h1 class="font-pronell text-4xl md:text-5xl lg:text-6xl font-normal leading-[1.05] text-white mb-6 tracking-tight animate-fade-up-2">
        {hero.title}
      </h1>
      <p class="text-base md:text-lg leading-relaxed text-white/70 mb-10 max-w-md animate-fade-up-3">
        {hero.text}
      </p>
      <div class="flex flex-wrap gap-3 mb-12 animate-fade-up-4">
        <a
          href="#ateliers"
          class="btn-shine text-base font-semibold px-8 py-3.5 rounded-full bg-coral text-white hover:bg-red-500 transition-colors shadow-lg shadow-coral/30"
        >
          Voir nos ateliers
        </a>
        <a
          href="#newsletter"
          class="text-base font-medium px-6 py-3.5 rounded-full bg-white/10 text-white border border-white/25 hover:bg-white/20 transition-all duration-200"
        >
          La Lettre Psy gratuite
        </a>
      </div>

      <div class="flex gap-0 border-t border-white/12 pt-7 animate-fade-up-4">
        {[stats.lettrePsy, stats.youtube, { value: String(activeAteliersCount), label: siteConfig.stats.ateliers.label }].map((s, i) => (
          <div class:list={[i < 2 && "pr-7 mr-7 border-r border-white/12"]}>
            <div class="font-pronell text-2xl md:text-3xl text-gold">{s.value}</div>
            <div class="text-xs text-white/50 mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
