---
interface Session {
  date: string;
  titre: string;
  details?: string[];
}

interface Props {
  programme: Session[];
}

const { programme } = Astro.props;

if (!programme || programme.length === 0) return;
---

<section class="py-12 md:py-16 bg-surface-2">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-12 reveal">
      <span
        class="text-xs font-bold tracking-widest uppercase text-ink-faint block mb-3"
        >Programme</span
      >
      <h2 class="font-aveton text-2xl md:text-3xl text-ink">
        Les sessions en détail
      </h2>
    </div>

    <div class="space-y-8">
      {
        programme.map((s, i) => (
          <div
            class="bg-brand/10 rounded-2xl border border-brand/20 p-6 md:p-8 reveal"
            class:list={[i === 1 ? "reveal-d1" : i === 2 ? "reveal-d2" : ""]}
          >
            <div class="flex items-start gap-4 mb-4">
              <div class="w-8 h-8 rounded-full bg-brand flex items-center justify-center shrink-0 mt-0.5">
                <span class="text-xs font-bold text-white">{i + 1}</span>
              </div>
              <div>
                {s.date && (
                  <span class="text-xs font-semibold text-brand">
                    {s.date}
                  </span>
                )}
                <h3 class="font-aveton text-lg text-ink leading-snug mt-0.5">
                  {s.titre}
                </h3>
              </div>
            </div>

            {s.details && s.details.length > 0 && (
              <ul class="space-y-2.5 pl-12">
                {s.details.map((d) => (
                  <li class="flex items-start gap-2.5 text-sm text-ink-light leading-snug">
                    <svg
                      class="w-4 h-4 text-brand shrink-0 mt-0.5"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                    <span>{d}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
