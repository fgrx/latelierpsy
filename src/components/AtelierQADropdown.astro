---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<details class="qa-dropdown bg-white rounded-xl border border-border overflow-hidden my-3">
  <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer text-left hover:bg-surface/50 transition-colors list-none [&::-webkit-details-marker]:hidden">
    <span class="text-sm font-medium text-ink leading-snug">{title}</span>
    <svg
      class="qa-icon w-4 h-4 text-ink-faint shrink-0 transition-transform duration-300"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      viewBox="0 0 24 24"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>
  <div class="qa-wrapper">
    <div class="qa-inner px-6 pb-5 text-sm text-ink-light leading-relaxed">
      <slot />
    </div>
  </div>
</details>

<style>
  .qa-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows 0.35s ease-out, opacity 0.25s ease-out;
  }
  .qa-wrapper.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
  }
  .qa-inner {
    overflow: hidden;
  }
  .qa-icon.is-open {
    transform: rotate(180deg);
  }
</style>

<script>
  document.querySelectorAll(".qa-dropdown").forEach((details) => {
    const summary = details.querySelector("summary");
    const wrapper = details.querySelector(".qa-wrapper");
    const icon = details.querySelector(".qa-icon");
    if (!summary || !wrapper) return;

    summary.addEventListener("click", (e) => {
      e.preventDefault();
      if (details.open) {
        wrapper.classList.remove("is-open");
        icon?.classList.remove("is-open");
        wrapper.addEventListener(
          "transitionend",
          () => {
            details.removeAttribute("open");
          },
          { once: true },
        );
      } else {
        details.setAttribute("open", "");
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            wrapper.classList.add("is-open");
            icon?.classList.add("is-open");
          });
        });
      }
    });
  });
</script>
