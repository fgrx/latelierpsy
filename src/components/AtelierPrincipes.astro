---
interface Props {
  principes: { title: string; description: string }[];
}

const { principes } = Astro.props;

if (!principes || principes.length === 0) return;

const ICONS = [
  "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
  "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
  "M13 10V3L4 14h7v7l9-11h-7z",
  "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
];
---

<section class="py-12 md:py-16 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-12 reveal">
      <span class="text-xs font-bold tracking-widest uppercase text-ink-faint block mb-3">Nos engagements</span>
      <h2 class="font-aveton text-2xl md:text-3xl text-ink">Les principes de cet atelier</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {principes.map((p, i) => {
        const icon = ICONS[i % ICONS.length];
        const delay = i === 0 ? "reveal" : i === 1 ? "reveal reveal-d1" : i === 2 ? "reveal reveal-d2" : "reveal reveal-d3";
        return (
          <div class:list={["p-6 rounded-2xl bg-surface border border-border/60", delay]}>
            <div class="w-9 h-9 rounded-lg bg-brand/10 flex items-center justify-center mb-4">
              <svg class="w-4.5 h-4.5 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <h3 class="font-semibold text-ink text-base mb-2">{p.title}</h3>
            <p class="text-sm text-ink-light leading-relaxed">{p.description}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
