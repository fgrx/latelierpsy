---
interface Formule {
  nom: string;
  prix: number;
  lien: string;
  details: string[];
}

interface Props {
  formules: Formule[];
}

const { formules } = Astro.props;

if (!formules || formules.length === 0) return;
---

<section class="py-12 md:py-16 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-12 reveal">
      <span
        class="text-[11px] font-bold tracking-widest uppercase text-ink-faint block mb-3"
        >Tarifs</span
      >
      <h2 class="font-aveton text-2xl md:text-3xl text-ink">
        Choisissez votre formule
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
      {
        formules.map((f, i) => (
          <div
            class:list={[
              "card-lift reveal bg-white rounded-2xl border border-border overflow-hidden",
              i === 1 ? "reveal-d1" : "",
            ]}
          >
            <div class="p-8">
              <h3 class="font-aveton text-xl text-ink mb-1">{f.nom}</h3>
              <div class="flex items-baseline gap-1 mb-6">
                <span class="font-pronell text-4xl text-brand">{f.prix}</span>
                <span class="text-[14px] text-ink-faint">€</span>
              </div>

              <ul class="space-y-3 mb-8">
                {f.details.map((d) => (
                  <li class="flex items-start gap-2.5 text-[13px] text-ink-light leading-snug">
                    <svg
                      class="w-4 h-4 text-brand shrink-0 mt-0.5"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    <span>{d}</span>
                  </li>
                ))}
              </ul>

              <a
                href={f.lien}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-shine block text-center text-[14px] font-semibold py-3 rounded-full transition-colors shadow-md bg-brand text-white hover:bg-brand-dark shadow-brand/20"
              >
                Acheter {f.prix}€
              </a>
              <p class="text-[11px] text-ink-faint text-center mt-2">
                Vous serez redirigé sur podia.com
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
