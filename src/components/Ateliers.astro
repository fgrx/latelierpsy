---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { siteConfig } from "../config";

const allAteliers = await getCollection("ateliers", ({ data }) => data.isActive || data.active);
const ateliers = allAteliers
  .sort((a, b) => {
    const da = a.data.date ? new Date(a.data.date).getTime() : 0;
    const db = b.data.date ? new Date(b.data.date).getTime() : 0;
    return db - da;
  })
  .slice(0, 3);
const section = siteConfig.ateliers;

const TAG_STYLES: Record<string, { bg: string; text: string }> = {
  "Estime de soi": { bg: "bg-surface", text: "text-brand" },
  "Émotions": { bg: "bg-red-50", text: "text-coral" },
  "Relations": { bg: "bg-blue-50", text: "text-blue-600" },
};
---

<section id="ateliers" class="bg-white py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-12 reveal">
      <span class="text-xs font-bold tracking-widest uppercase text-ink-faint block mb-3">{section.surtitle}</span>
      <h2 class="font-pronell text-3xl md:text-4xl font-normal text-ink mb-3">{section.title}</h2>
      <p class="text-base text-ink-light leading-relaxed max-w-lg mx-auto">
        {section.text}
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {ateliers.map((a, i) => {
        const style = TAG_STYLES[a.data.tag] || { bg: "bg-surface", text: "text-brand" };
        const imgSrc = a.data.image || a.data.bannerImage;
        return (
          <a href={`/ateliers/${a.id}`} class:list={["reveal block", i === 1 ? "reveal-d2" : i === 2 ? "reveal-d3" : "reveal-d1", "card-lift bg-white rounded-2xl overflow-hidden border border-surface shadow-sm"]}>
            {imgSrc ? (
              <div class="overflow-hidden h-48">
                <Image
                  src={imgSrc}
                  alt={a.data.title}
                  width={600}
                  height={400}
                  format="webp"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                />
              </div>
            ) : a.data.logoImage ? (
              <div class:list={["flex items-center justify-center h-56", a.data.colorPresentation || "bg-brand"]}>
                <Image
                  src={a.data.logoImage}
                  alt={a.data.title}
                  width={144}
                  height={144}
                  format="webp"
                  class="w-36 h-36 object-contain drop-shadow"
                />
              </div>
            ) : (
              <div class="flex items-center justify-center h-48 bg-brand">
                <span class="text-white font-aveton text-lg">{a.data.tag}</span>
              </div>
            )}
            <div class="p-6">
              <span class:list={["inline-flex text-2xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-3", style.bg, style.text]}>
                {a.data.tag}
              </span>
              <div class="font-aveton text-xl leading-snug text-ink mb-2">{a.data.title}</div>
              <div class="text-sm leading-relaxed text-ink-faint mb-5">{a.data.description}</div>
              <span class="group flex items-center gap-2 text-sm font-semibold text-brand">
                En savoir plus
                <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>

    <div class="text-center mt-10 reveal">
      <a href="/ateliers" class="btn-shine text-sm font-semibold px-8 py-3 rounded-full bg-brand text-white hover:bg-brand-dark transition-colors shadow-md shadow-brand/20">
        Voir tous les ateliers →
      </a>
    </div>
  </div>
</section>
