---
import NewsletterForm from "./NewsletterForm.vue";
import { siteConfig } from "../config";
import { getAllStats } from "../lib/fetch-stats";

const newsletter = siteConfig.newsletter;
const stats = await getAllStats();
---

<section id="newsletter" class="bg-neutral py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12 md:gap-16 items-center">
    <div class="reveal">
      <span class="text-xs font-bold tracking-widest uppercase text-brand block mb-3">{newsletter.surtitle}</span>
      <h2 class="font-pronell text-3xl md:text-4xl font-normal text-ink leading-tight mb-4">
        {newsletter.title}
      </h2>
      <p class="text-base leading-relaxed text-ink-light mb-6">
        {newsletter.text}
      </p>
      <div class="flex flex-wrap gap-2">
        {newsletter.perks.map((p) => (
          <span class="text-xs font-semibold px-4 py-1.5 rounded-full bg-brand/10 text-brand">{p}</span>
        ))}
      </div>
    </div>
    <div class="reveal reveal-d1 bg-white rounded-2xl p-8 shadow-xl shadow-brand/10">
      <div class="font-aveton text-xl text-ink mb-1">S'abonner à la Lettre Psy</div>
      <div class="text-sm text-ink-faint mb-6">Rejoignez les {stats.lettrePsy.value} lecteurs</div>
      <NewsletterForm client:load count={stats.lettrePsy.value} apiUrl={newsletter.apiUrl} campaignId={newsletter.defaultCampaignId} />
    </div>
  </div>
</section>
